" Editor options (no plugin declarations).

set nocompatible
syntax on
filetype plugin indent on

set number
set relativenumber
set scrolloff=15
set cursorline
set tabstop=4
set shiftwidth=4
set expandtab
set wildmenu
set hlsearch
set incsearch
set shortmess+=s
set colorcolumn=80
set hidden
set laststatus=2
set ttimeoutlen=150

let mapleader = "\<Space>"

set path+=**
